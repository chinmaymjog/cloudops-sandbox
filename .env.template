# ==============================================================================
# DevOps Lab - Global Configuration Template
# ==============================================================================
# Copy this file to '.env' and fill in the values.
# 🚨 NEVER commit the actual '.env' file to version control!

# 🌍 Global Domain
# The root domain used for all routed services (e.g., example.com)
# For local development, 'lab.local' is recommended.
APP_DOMAIN=lab.ilearndevops.in

# 📦 Docker Image Tags (Strictly Required)
GRAFANA_TAG=13.0.1
MYSQL_TAG=9.7.0
PHPMYADMIN_TAG=5.2.3
N8N_TAG=2.18.7
POSTGRES_TAG=18.3
ADMINER_TAG=5.4.2
PORTAINER_TAG=2.39.1
PROMETHEUS_TAG=v3.11.3
TRAEFIK_TAG=v3.6.15
WUD_TAG=8.2.2
KEYCLOAK_TAG=26.6.1

# 🌐 Global Settings
GENERIC_TIMEZONE=Asia/Calcutta
TZ=Asia/Calcutta

# 🛡️ Traefik (Proxy & DNS/Certificates)
# Your Cloudflare account email
CF_API_EMAIL=example@example.com
# Cloudflare DNS API Token (Permissions: Zone.DNS:Edit, Zone.Zone:Read)
CF_DNS_API_TOKEN=your_cloudflare_api_token
# Basic Authentication for Dashboards (format: user:hashed_password)
# Generate with: echo $(htpasswd -nbu user password) | sed -e s/\\$/\\$\\$/g
BASIC_AUTH=htpasswd_string_here

# 🐘 PostgreSQL Database
POSTGRES_PASSWORD=postgres_secure_password
N8N_DB_PASSWORD=n8n_secure_db_password
GRAFANA_DB_PASSWORD=grafana_secure_db_password

# 🐬 MySQL Database
MYSQL_ROOT_PASSWORD=mysql_secure_root_password

# ⚙️ Automation (n8n)
# Encryption key for n8n credentials (openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here

# 📢 WUD (What's Up Docker) Slack Trigger
WUD_TRIGGER_SLACK_SUPPORT_TOKEN=your_slack_token_here
WUD_TRIGGER_SLACK_SUPPORT_CHANNEL=your_slack_channel_here
WUD_TRIGGER_SLACK_SUPPORT_THRESHOLD=major-only
WUD_REGISTRY_CUSTOM_N8N_URL=https://docker.n8n.io

# 🔑 Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_secure_admin_password
KEYCLOAK_DB_PASSWORD=keycloak_secure_db_password
