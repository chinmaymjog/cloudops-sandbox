# ==============================================================================
# AI-Orchestrator Remote Environment Template (env.sample)
# ==============================================================================
# This file is used by CI/CD to inject secrets via 'envsubst'.

# Credentials
ORCHESTRATOR_TOKEN=$ORCHESTRATOR_TOKEN

# Networking
# The domain AI-Orchestrator will be accessible at (e.g., orchestrator.lab.local)
APP_DOMAIN=$APP_DOMAIN

# Repository allowlist
# Use exactly one of the following:
# 1. Inline JSON via ALLOWED_REPOS_JSON
# 2. Path to a mounted file via ALLOWED_REPOS_FILE
#
# Example JSON:
# {"sample-repo":{"clone_url":"git@gitlab.com:your-group/sample-repo.git","default_branch":"main"}}
ALLOWED_REPOS_JSON=$ALLOWED_REPOS_JSON
ALLOWED_REPOS_FILE=$ALLOWED_REPOS_FILE
