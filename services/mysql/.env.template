# ==============================================================================
# MySQL Remote Environment Template (env.sample)
# ==============================================================================
# This file is used by CI/CD to inject secrets via 'envsubst'.

# 📦 Image Version
MYSQL_TAG=$MYSQL_TAG
PHPMYADMIN_TAG=$PHPMYADMIN_TAG

# 🌐 Networking
# The domain used for routing to UI services like phpMyAdmin (e.g., mysql.lab.local)
APP_DOMAIN=$APP_DOMAIN

# 🔑 Credentials
# Root password for full administrative access
MYSQL_ROOT_PASSWORD=$MYSQL_ROOT_PASSWORD
