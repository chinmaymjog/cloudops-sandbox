# ==============================================================================
# n8n Remote Environment Template (env.sample)
# ==============================================================================
# This file is used by CI/CD to inject secrets via 'envsubst'.

# 📦 Image Version
N8N_TAG=$N8N_TAG

# 🌐 Networking
# The domain n8n will be accessible at (e.g., n8n.lab.local)
APP_DOMAIN=$APP_DOMAIN

# 🌍 Timezone
GENERIC_TIMEZONE=$GENERIC_TIMEZONE
TZ=$GENERIC_TIMEZONE

# 🔧 Security & Authentication (Web Access)
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=$N8N_ENCRYPTION_KEY

# 🗄️ Database Configuration (Persistence)
# By default, n8n uses SQLite. For production, use PostgreSQL.
DB_TYPE=$DB_TYPE
DB_POSTGRESDB_HOST=$DB_POSTGRESDB_HOST
DB_POSTGRESDB_PORT=$DB_POSTGRESDB_PORT
DB_POSTGRESDB_DATABASE=$DB_POSTGRESDB_DATABASE
DB_POSTGRESDB_USER=$DB_POSTGRESDB_USER
DB_POSTGRESDB_PASSWORD=$DB_POSTGRESDB_PASSWORD
